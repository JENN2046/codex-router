{
  "name": "codex-router",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Policy-based Codex execution governance for authorization, preview, evidence, retain, and rollback.",
  "files": [
    "dist/packages/authorization-kernel/src/index.js",
    "dist/packages/capability/src/index.js",
    "dist/packages/codex-adapter/src/command-approval.js",
    "dist/packages/codex-adapter/src/index.js",
    "dist/packages/codex-adapter/src/permission-profile.js",
    "dist/packages/codex-adapter/src/v2-wire.js",
    "dist/packages/file-change-preview/src/index.js",
    "dist/packages/kernel-contracts/src/codex-governance.js",
    "dist/packages/kernel-contracts/src/core.js",
    "dist/packages/kernel-contracts/src/public.js",
    "dist/packages/provider-core/src/governance-public.js",
    "dist/packages/public-api/src/codex-adapter.js",
    "dist/packages/public-api/src/evidence.js",
    "dist/packages/public-api/src/policy.js",
    "dist/packages/public-api/src/protocol.js",
    "dist/packages/public-api/src/provider.js",
    "dist/packages/retain-control/src/index.js",
    "dist/packages/authorization-kernel/src/index.d.ts",
    "dist/packages/codex-adapter/src/index.d.ts",
    "dist/packages/codex-adapter/src/permission-profile.d.ts",
    "dist/packages/codex-adapter/src/v2-wire.d.ts",
    "dist/packages/file-change-preview/src/index.d.ts",
    "dist/packages/kernel-contracts/src/codex-governance.d.ts",
    "dist/packages/kernel-contracts/src/core.d.ts",
    "dist/packages/kernel-contracts/src/public.d.ts",
    "dist/packages/provider-core/src/governance-public.d.ts",
    "dist/packages/public-api/src/codex-adapter.d.ts",
    "dist/packages/public-api/src/evidence.d.ts",
    "dist/packages/public-api/src/policy.d.ts",
    "dist/packages/public-api/src/protocol.d.ts",
    "dist/packages/public-api/src/provider.d.ts",
    "dist/packages/retain-control/src/index.d.ts",
    "README.AGENTS_OS.md",
    "README.md"
  ],
  "exports": {
    "./protocol": {
      "types": "./dist/packages/public-api/src/protocol.d.ts",
      "import": "./dist/packages/public-api/src/protocol.js"
    },
    "./policy": {
      "types": "./dist/packages/public-api/src/policy.d.ts",
      "import": "./dist/packages/public-api/src/policy.js"
    },
    "./codex-adapter": {
      "types": "./dist/packages/public-api/src/codex-adapter.d.ts",
      "import": "./dist/packages/public-api/src/codex-adapter.js"
    },
    "./evidence": {
      "types": "./dist/packages/public-api/src/evidence.d.ts",
      "import": "./dist/packages/public-api/src/evidence.js"
    },
    "./provider": {
      "types": "./dist/packages/public-api/src/provider.d.ts",
      "import": "./dist/packages/public-api/src/provider.js"
    }
  },
  "scripts": {
    "build": "node --import tsx scripts/clean-build-output.ts && tsc -p tsconfig.json",
    "governance": "node --import tsx scripts/run-governance-check.ts",
    "docs:governance": "node --import tsx scripts/check-governance-docs.ts",
    "validate:daily": "node --import tsx scripts/run-governance-check.ts tier daily",
    "validate:pr": "node --import tsx scripts/run-governance-check.ts tier pr",
    "validate:release": "node --import tsx scripts/run-governance-check.ts tier release",
    "demo:runtime-governance": "node --import tsx scripts/run-runtime-governance-demo.ts",
    "model:check": "node --import tsx scripts/check-codex-cli-models.ts",
    "preflight:codex-cli-env": "node --import tsx scripts/run-codex-cli-environment-preflight.ts",
    "smoke:contract": "node --import tsx scripts/run-codex-cli-contract-smoke.ts",
    "smoke:readonly:real": "node --import tsx scripts/run-codex-cli-real-readonly-smoke.ts",
    "smoke:telemetry": "node --import tsx scripts/run-codex-cli-readonly-smoke-telemetry.ts",
    "smoke:workspace-write:telemetry": "node --import tsx scripts/run-codex-cli-workspace-write-smoke-telemetry.ts",
    "smoke:app-server:file-change:preflight": "node --import tsx scripts/run-codex-app-server-file-change-smoke.ts",
    "test:app-server:offline-harness": "node --import tsx --test tests/codex-app-server-live-smoke-safety.test.ts",
    "test:app-server:no-environment-proposal": "node --import tsx --test tests/codex-app-server-no-environment-proposal.test.ts",
    "test:app-server:runtime-tool-inventory": "node --import tsx --test tests/codex-app-server-runtime-tool-inventory-attestation.test.ts",
    "test:offline-execution-capsule": "node --import tsx --test tests/offline-execution-capsule.test.ts",
    "audit:app-server:proposal-capability": "node --import tsx scripts/run-codex-app-server-proposal-capability-audit.ts",
    "audit:app-server:exact-version-security-review": "node --import tsx scripts/run-codex-app-server-exact-version-security-review.ts",
    "audit:app-server:runtime-tool-inventory": "node --import tsx scripts/run-codex-app-server-runtime-tool-inventory-audit.ts",
    "audit:offline-execution-capsule-boundary": "node --import tsx scripts/run-offline-execution-capsule-boundary-audit.ts",
    "canary": "node --import tsx scripts/run-canary-test.ts",
    "canary:write": "node --import tsx scripts/run-canary-test.ts --risk medium",
    "canary:external": "node --import tsx scripts/run-canary-test.ts --risk high",
    "canary:workspace-write:real": "node --import tsx scripts/run-workspace-write-real-canary-local.ts",
    "evidence:collect": "node --import tsx scripts/collect-evidence.ts",
    "test:package-consumer": "node --import tsx scripts/test-package-consumer.ts",
    "audit:clean-build-determinism": "node --import tsx scripts/run-clean-build-determinism-audit.ts",
    "test:coverage:authorization": "node --experimental-test-coverage --test-coverage-include=\"packages/authorization-kernel/src/**\" --test-coverage-branches=90 --import tsx --test tests/authorization-kernel.test.ts",
    "test:coverage:offline-execution-capsule": "node --experimental-test-coverage --test-coverage-include=\"packages/execution-capsule/src/**\" --test-coverage-branches=90 --import tsx --test tests/offline-execution-capsule.test.ts tests/offline-execution-capsule-fake-worker-input-gate.test.ts tests/offline-execution-capsule-fake-worker-output-gate.test.ts tests/offline-execution-capsule-review-closeout.test.ts",
    "test:coverage:preview": "node --experimental-test-coverage --test-coverage-include=\"packages/file-change-preview/src/**\" --test-coverage-branches=90 --import tsx --test tests/file-change-preview.test.ts",
    "test:coverage:retain": "node --experimental-test-coverage --test-coverage-include=\"packages/retain-control/src/**\" --test-coverage-branches=90 --import tsx --test tests/retain-control.test.ts",
    "test:governance-coverage": "npm run test:coverage:authorization && npm run test:coverage:preview && npm run test:coverage:retain && npm run test:coverage:offline-execution-capsule",
    "test:governance-properties": "node --import tsx --test --test-name-pattern=property tests/file-change-preview.test.ts tests/retain-control.test.ts tests/codex-app-server-adapter.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx scripts/run-tests.ts"
  },
  "dependencies": {
    "yaml": "^2.8.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.19.3",
    "typescript": "6.0.3"
  }
}
