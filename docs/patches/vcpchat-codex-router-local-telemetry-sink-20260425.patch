+            guidance: guidance ? {
+                memoryRequired: typeof guidance.memoryRequired === 'boolean' ? guidance.memoryRequired : null,
+                telemetryMandatory: typeof guidance.telemetryMandatory === 'boolean' ? guidance.telemetryMandatory : null,
+                requiredMinReusable: typeof guidance.requiredMinReusable === 'number' ? guidance.requiredMinReusable : null
+            } : null
+        } : null
+    };
+}
+
+function sanitizeCodexRouterTelemetryEvent(event = {}) {
+    return {
+        level: typeof event.level === 'string' ? event.level : null,
+        message: typeof event.message === 'string' ? event.message : null,
+        correlationId: typeof event.correlationId === 'string' ? event.correlationId : null,
+        context: sanitizeCodexRouterTelemetryContext(event.context)
+    };
+}
+
+function createCodexRouterTelemetryStore(filePath = CODEX_ROUTER_TELEMETRY_FILE) {
+    return {
+        async record(event) {
+            await fs.ensureDir(path.dirname(filePath));
+            const entry = {
+                recordedAt: new Date().toISOString(),
+                event: sanitizeCodexRouterTelemetryEvent(event)
+            };
+            await fs.appendFile(filePath, `${JSON.stringify(entry)}\n`, 'utf8');
+        }
+    };
+}
