+function sanitizeCodexRouterTelemetryContext(context = {}) {
+    if (!context || typeof context !== 'object') return {};
+    const memory = context.memory && typeof context.memory === 'object' ? context.memory : null;
+    const guidance = memory?.guidance && typeof memory.guidance === 'object' ? memory.guidance : null;
+    return {
+        taskId: typeof context.taskId === 'string' ? context.taskId : null,
+        decisionId: typeof context.decisionId === 'string' ? context.decisionId : null,
+        ok: typeof context.ok === 'boolean' ? context.ok : null,
+        errors: sanitizeCodexRouterStringArray(context.errors),
