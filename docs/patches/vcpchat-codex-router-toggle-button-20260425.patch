+}
+
+function setCodexRouterModeEnabled(enabled, options = {}) {
+    const nextEnabled = Boolean(enabled);
+    const client = getCodexRouterHostClient();
+    const isAvailable = Boolean(client && typeof client.run === 'function');
+
+    if (nextEnabled && !isAvailable) {
+        codexRouterModeEnabled = false;
+        saveCodexRouterModeSetting(false);
+        updateCodexRouterToggleButtonState();
+        if (options.notify !== false) {
+            notifyCodexRouterCommand('Codex Router host is not available in this window.', 'error');
