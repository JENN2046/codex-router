+        notifyCodexRouterCommand(
+            codexRouterModeEnabled
+                ? 'Codex Router mode enabled. Normal send now runs governed tasks.'
+                : 'Codex Router mode disabled. Normal send uses VCPChat.',
+            codexRouterModeEnabled ? 'success' : 'info'
+        );
+    }
+
+    return true;
+}
