+function getCodexRouterResultPayload(result) {
+    return result?.result && typeof result.result === 'object' ? result.result : (result || {});
+}
+
+function formatCodexRouterValue(value) {
+    if (value === null || value === undefined || value === '') return '未提供';
+    if (typeof value === 'boolean') return value ? '是' : '否';
+    return String(value);
+}
+
+function formatCodexRouterList(items, mapper, limit = 6) {
+    if (!Array.isArray(items) || items.length === 0) return [];
+    return items.slice(0, limit).map(mapper).filter(Boolean);
+}
+
+function getCodexRouterPrimitiveName(item) {
+    if (!item) return '';
+    if (typeof item === 'string') return item;
+    return item.primitive || item.name || item.type || item.action || '';
+}
+
+function buildCodexRouterVisibleReply(result, task) {
+    const payload = getCodexRouterResultPayload(result);
+    const executionStatus =
+        payload.executionStatus
+        || payload.execution?.status
+        || payload.status
+        || result?.status
+        || 'completed';
+    const plannedPrimitives = formatCodexRouterList(
+        payload.plannedPrimitives || payload.plan?.steps,
+        item => getCodexRouterPrimitiveName(item)
+    );
+    const executedSteps = formatCodexRouterList(
+        payload.executedStepStatuses || payload.execution?.steps,
+        item => {
+            if (!item) return '';
+            const name = getCodexRouterPrimitiveName(item);
+            const status = item.status || item.resultStatus || item.outcome || '';
+            return status ? `${name || 'step'}：${status}` : name;
+        }
+    );
+    const blockingReasons = formatCodexRouterList(
+        payload.blockingReasons || payload.preflight?.blockingReasons,
+        item => typeof item === 'string' ? item : (item?.reason || item?.message || '')
+    );
+
+    const lines = [
+        '### Codex Router 执行结果',
+        '',
+        `- 状态：${formatCodexRouterExecutionStatus(executionStatus)}`,
+        `- 策略版本：${formatCodexRouterValue(payload.policyVersion || payload.decision?.policyVersion)}`,
+        `- 模型：${formatCodexRouterValue(payload.selectedModel || payload.execution?.selectedModel)}`,
+        `- 执行档位：${formatCodexRouterValue(payload.executionProfile || payload.execution?.executionProfile)}`,
+        `- 工具权限：${formatCodexRouterValue(payload.toolAccess || payload.execution?.toolAccess)}`,
+        `- 是否需要审批：${formatCodexRouterValue(payload.approvalRequired ?? payload.approval?.required)}`,
+        `- 任务编号：${formatCodexRouterValue(task?.taskId)}`
+    ];
+
+    if (plannedPrimitives.length > 0) {
+        lines.push(`- 计划动作：${plannedPrimitives.join('、')}`);
+    }
+    if (executedSteps.length > 0) {
+        lines.push(`- 执行动作：${executedSteps.join('、')}`);
+    }
+    if (blockingReasons.length > 0) {
+        lines.push(`- 阻塞原因：${blockingReasons.join('；')}`);
+    }
+
+    lines.push('', '原始结果已保存在本窗口的 `window.__lastCodexRouterHostRun`，当前聊天历史也会记录这条摘要。');
+    return lines.join('\n');
+}
+
+async function saveCurrentCodexRouterVisibleHistory() {
+    if (!currentSelectedItem?.id || !currentTopicId) return false;
+    const historyToSave = currentChatHistory.filter(message => !message?.isThinking);
+    if (currentSelectedItem.type === 'group' && typeof chatAPI?.saveGroupChatHistory === 'function') {
+        await chatAPI.saveGroupChatHistory(currentSelectedItem.id, currentTopicId, historyToSave);
+        return true;
+    }
+    if (typeof chatAPI?.saveChatHistory === 'function') {
+        await chatAPI.saveChatHistory(currentSelectedItem.id, currentTopicId, historyToSave);
+        return true;
+    }
+    return false;
+}
+
+async function appendCodexRouterVisibleMessage(message, options = {}) {
+    if (!window.messageRenderer || typeof window.messageRenderer.renderMessage !== 'function') {
+        return false;
+    }
+
+    await window.messageRenderer.renderMessage(message);
+    if (options.persist !== false && !message.isThinking) {
+        currentChatHistory.push(message);
+        await saveCurrentCodexRouterVisibleHistory();
+    }
+    return true;
+}
