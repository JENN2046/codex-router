 function notifyCodexRouterCommand(message, type = 'info') {
     if (window.uiHelperFunctions && typeof window.uiHelperFunctions.showToastNotification === 'function') {
         window.uiHelperFunctions.showToastNotification(message, type);
     }
 }
 
+function loadCodexRouterModeSetting() {
+    try {
+        return window.localStorage?.getItem(CODEX_ROUTER_MODE_STORAGE_KEY) === 'true';
+    } catch (error) {
+        console.warn('[CodexRouterHost] Failed to load toggle state:', error);
+        return false;
+    }
+}
+
+function saveCodexRouterModeSetting(enabled) {
+    try {
+        window.localStorage?.setItem(CODEX_ROUTER_MODE_STORAGE_KEY, enabled ? 'true' : 'false');
+    } catch (error) {
+        console.warn('[CodexRouterHost] Failed to save toggle state:', error);
+    }
+}
+
+function getCodexRouterHostClient() {
+    const client = window.codexRouterHostClient || createCodexRouterHostClient(window);
+    if (client && !window.codexRouterHostClient) {
+        window.codexRouterHostClient = client;
+    }
+    return client;
+}
+
+function updateCodexRouterToggleButtonState() {
+    if (!codexRouterToggleBtn) return;
+
+    const client = getCodexRouterHostClient();
+    const isAvailable = Boolean(client && typeof client.run === 'function');
+    const isEnabled = isAvailable && codexRouterModeEnabled;
+
+    codexRouterToggleBtn.disabled = !isAvailable;
+    codexRouterToggleBtn.classList.toggle('router-enabled', isEnabled);
+    codexRouterToggleBtn.classList.toggle('router-disabled', isAvailable && !isEnabled);
+    codexRouterToggleBtn.classList.toggle('router-unavailable', !isAvailable);
+    codexRouterToggleBtn.dataset.codexRouterMode = isEnabled ? 'enabled' : (isAvailable ? 'disabled' : 'unavailable');
+    codexRouterToggleBtn.setAttribute('aria-pressed', isEnabled ? 'true' : 'false');
+    codexRouterToggleBtn.title = !isAvailable
+        ? 'Codex Router: unavailable in this window'
+        : (isEnabled
+            ? 'Codex Router: on, normal send runs a governed task'
+            : 'Codex Router: off, normal send uses VCPChat');
+}
+
+function setCodexRouterModeEnabled(enabled, options = {}) {
+    const nextEnabled = Boolean(enabled);
+    const client = getCodexRouterHostClient();
+    const isAvailable = Boolean(client && typeof client.run === 'function');
+
+    if (nextEnabled && !isAvailable) {
+        codexRouterModeEnabled = false;
+        saveCodexRouterModeSetting(false);
+        updateCodexRouterToggleButtonState();
+        if (options.notify !== false) {
+            notifyCodexRouterCommand('Codex Router host is not available in this window.', 'error');
+        }
+        return false;
+    }
+
+    codexRouterModeEnabled = nextEnabled;
+    saveCodexRouterModeSetting(codexRouterModeEnabled);
+    updateCodexRouterToggleButtonState();
+
+    if (options.notify !== false) {
+        notifyCodexRouterCommand(
+            codexRouterModeEnabled
+                ? 'Codex Router mode enabled. Normal send now runs governed tasks.'
+                : 'Codex Router mode disabled. Normal send uses VCPChat.',
+            codexRouterModeEnabled ? 'success' : 'info'
+        );
+    }
+
+    return true;
+}
+
+function setupCodexRouterToggleButton() {
+    if (!codexRouterToggleBtn) return;
+
+    codexRouterToggleBtn.addEventListener('click', () => {
+        setCodexRouterModeEnabled(!codexRouterModeEnabled);
+    });
+
+    updateCodexRouterToggleButtonState();
+}
