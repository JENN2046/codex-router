+function getCodexRouterExecutionStatus(result) {
+    const payload = getCodexRouterResultPayload(result);
+    const executionResult = getCodexRouterExecutionResult(payload);
+    const decisionResult = getCodexRouterDecisionResult(payload);
+    return executionResult.status
+        || payload.executionStatus
+        || payload.execution?.status
+        || payload.status
+        || decisionResult.status
+        || result?.status
+        || 'completed';
+}
+
+function isCodexRouterRunAllowedForAgent(result) {
+    const payload = getCodexRouterResultPayload(result);
+    const executionStatus = String(getCodexRouterExecutionStatus(result)).toLowerCase();
+    const blockingReasons = payload.blockingReasons || getCodexRouterDecisionResult(payload).blockingReasons || getCodexRouterExecutionResult(payload).blockingReasons || [];
+    return !['not_ready', 'failed', 'blocked', 'error'].includes(executionStatus) && (!Array.isArray(blockingReasons) || blockingReasons.length === 0);
+}
